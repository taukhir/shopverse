{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Explore centralized logs",
      "type": "link",
      "url": "/explore?left={\"datasource\":\"Loki\"}",
      "targetBlank": false
    },
    {
      "title": "Explore distributed traces",
      "type": "link",
      "url": "/explore?left={\"datasource\":\"Zipkin\"}",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "type": "stat",
      "title": "Active SAGAs",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "expr": "sum(increase(shopverse_saga_transitions_total{stage=\"PAYMENT_PROCESSING\"}[1h])) - sum(increase(shopverse_saga_transitions_total{stage=~\"ORDER_CONFIRMED|PAYMENT_FAILED|INVENTORY_REJECTED\"}[1h]))",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "SAGA Transitions",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "expr": "sum by (stage) (rate(shopverse_saga_transitions_total[5m]))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 9, "x": 6, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Payment Outcomes",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "expr": "sum by (status) (rate(shopverse_payment_outcomes_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 9, "x": 15, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Inventory Reservation Conflicts",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "expr": "sum by (reason) (increase(shopverse_inventory_reservation_conflicts_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "type": "timeseries",
      "title": "Expired Reservations",
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {
          "expr": "increase(shopverse_inventory_reservations_expired_total[5m])",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    }
  ],
  "refresh": "10s",
  "schemaVersion": 41,
  "tags": ["shopverse", "saga", "commerce"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "Shopverse Commerce Operations",
  "uid": "shopverse-commerce-operations",
  "version": 1
}
