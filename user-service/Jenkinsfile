pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    parameters {
        booleanParam(name: 'BUILD_DOCKER_IMAGE', defaultValue: true, description: 'Build the user-service Docker image.')
        booleanParam(name: 'DEPLOY_LOCALLY', defaultValue: false, description: 'Deploy the built image to the local Docker Compose stack.')
        string(name: 'IMAGE_NAME', defaultValue: 'shopverse/user-service', description: 'Docker image name.')
        string(name: 'IMAGE_TAG', defaultValue: '', description: 'Optional Docker image tag. Defaults to Jenkins build number and Git SHA.')
    }

    environment {
        DOCKER_BUILDKIT = '1'
        COMPOSE_DOCKER_CLI_BUILD = '1'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Resolve Image Tag') {
            when {
                expression { params.BUILD_DOCKER_IMAGE }
            }
            steps {
                script {
                    def shortSha = env.GIT_COMMIT ? env.GIT_COMMIT.take(8) : 'local'
                    env.RESOLVED_IMAGE_TAG = params.IMAGE_TAG?.trim() ?: "${env.BUILD_NUMBER}-${shortSha}"
                    env.USER_SERVICE_IMAGE = "${params.IMAGE_NAME}:${env.RESOLVED_IMAGE_TAG}"
                    echo "User service image: ${env.USER_SERVICE_IMAGE}"
                }
            }
        }

        stage('Build And Test') {
            steps {
                dir('user-service') {
                    sh 'chmod +x ./gradlew'
                    sh './gradlew clean build --no-daemon'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'user-service/build/test-results/test/*.xml'
                    archiveArtifacts allowEmptyArchive: true, artifacts: 'user-service/build/reports/tests/test/**'
                }
            }
        }

        stage('Build Docker Image') {
            when {
                expression { params.BUILD_DOCKER_IMAGE }
            }
            steps {
                sh 'docker build -t "${USER_SERVICE_IMAGE}" ./user-service'
            }
        }

        stage('Verify Docker Image') {
            when {
                expression { params.BUILD_DOCKER_IMAGE }
            }
            steps {
                sh 'docker image inspect "${USER_SERVICE_IMAGE}"'
            }
        }

        stage('Deploy Locally') {
            when {
                expression { params.BUILD_DOCKER_IMAGE && params.DEPLOY_LOCALLY }
            }
            steps {
                sh 'docker tag "${USER_SERVICE_IMAGE}" shopverse/user-service:local'
                sh 'docker compose up -d user-service'
                sh '''
                    for attempt in $(seq 1 40); do
                      status=$(docker inspect -f '{{.State.Health.Status}}' shopverse-user-service 2>/dev/null || true)
                      if [ "$status" = "healthy" ]; then
                        echo "user-service is healthy"
                        exit 0
                      fi
                      echo "Waiting for user-service health... attempt ${attempt}/40 current=${status:-unknown}"
                      sleep 5
                    done

                    docker compose ps user-service
                    docker compose logs --tail=200 user-service
                    exit 1
                '''
            }
        }
    }
}
